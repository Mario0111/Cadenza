# Copy this file to .env and fill in real values. .env is never committed.

# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
# Local MongoDB, or a MongoDB Atlas connection string.
MONGODB_URI=mongodb://127.0.0.1:27017/cadenza

# --- Auth ---
# Use a long random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Admin seed (used by: npm run seed:admin) ---
ADMIN_NAME=Cadenza Admin
ADMIN_EMAIL=admin@cadenza.local
ADMIN_PASSWORD=change-this-admin-password
